<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Left Sidebar -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:background="#0A0E1A"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="top">

        <!-- Camera Icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="80dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1F2937"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera"/>
        </androidx.cardview.widget.CardView>

        <!-- Globe Icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnGlobe"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1F2937"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_globe"/>
        </androidx.cardview.widget.CardView>

        <!-- Settings Icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#1F2937"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Main Content Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/sidebar">

        <!-- Top Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="@color/black">

            <!-- AI Avatar -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_purple"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jack AI"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Assistant"
                    android:textColor="@color/gray"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Volume Icon -->
            <ImageView
                android:id="@+id/btnVolume"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_volume"
                android:layout_marginEnd="16dp"/>

            <!-- Settings Icon (Top Right) -->
            <ImageView
                android:id="@+id/btnSettingsTop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/header"
            android:background="#1F2937"/>

        <!-- Chat Messages RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/divider"
            android:layout_above="@id/bottomArea"
            android:padding="16dp"
            android:clipToPadding="false"
            android:scrollbars="vertical"/>

        <!-- Bottom Area with Mic Button -->
        <RelativeLayout
            android:id="@+id/bottomArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:padding="24dp">

            <!-- Microphone Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnMicrophone"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_centerHorizontal="true"
                app:cardBackgroundColor="#3B82F6"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_microphone"/>
            </androidx.cardview.widget.CardView>

            <!-- Instruction Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/btnMicrophone"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Hold     Space     to talk  •  Enter     to send message"
                android:textColor="@color/gray"
                android:textSize="12sp"/>

        </RelativeLayout>

    </RelativeLayout>

</RelativeLayout>