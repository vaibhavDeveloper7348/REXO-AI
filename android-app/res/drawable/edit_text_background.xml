<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color of the EditText -->
    <solid android:color="#2C2C2C" />

    <!-- Rounded corners -->
    <corners android:radius="8dp" />

    <!-- Border/Stroke around the EditText -->
    <stroke
        android:width="1dp"
        android:color="#404040" />

    <!-- Optional: Add some padding inside -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>